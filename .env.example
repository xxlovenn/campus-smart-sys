# Copy to project root as .env for docker compose variable substitution
POSTGRES_USER=campus
POSTGRES_PASSWORD=campus_secret_change_me
POSTGRES_DB=campus_smart

# Backend (used inside container; host.docker.internal for local DB outside compose)
DATABASE_URL=postgresql://campus:campus_secret_change_me@postgres:5432/campus_smart?schema=public
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# Frontend public URL (browser -> backend through compose network uses service name in server components;
# for client-side fetch from browser use your machine IP or localhost with mapped port)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
