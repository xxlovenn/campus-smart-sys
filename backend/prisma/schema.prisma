generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ORG_ADMIN
  LEAGUE_ADMIN
}

enum OrganizationMemberRole {
  MEMBER
  ORG_ADMIN
}

enum OrganizationStatus {
  ACTIVE
  PAUSED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TaskApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum TaskSource {
  ORG_REQUEST
  LEAGUE_PUBLISHED
}

enum TaskTargetType {
  ORGS
  ALL_STUDENTS
  GRADE
  MAJOR
  CLASS
}

enum OrgReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PlanSource {
  PERSONAL
  ORG_TASK
}

enum ActivityLogType {
  ORGANIZATION
  TASK
}

enum PlanPriority {
  LOW
  MEDIUM
  HIGH
}

enum ProfileReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProfileItemAction {
  ADD
  DELETE
}

enum ProfileItemRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  studentId    String?  @unique
  idCard       String?  @unique
  phone        String?
  grade        String?
  major        String?
  className    String?
  isOrgAccount Boolean  @default(false)
  role         UserRole @default(STUDENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships       OrganizationMember[]
  ledOrganizations  Organization[]       @relation("OrganizationLeader")
  adminOrganizations Organization[]      @relation("OrganizationAdminUser")
  createdTasks      Task[]               @relation("TaskCreator")
  assignedTasks     Task[]               @relation("TaskAssignee")
  reviewedTasks     Task[]               @relation("TaskReviewer")
  reviewedProfiles  Profile[]            @relation("ProfileReviewer")
  reviewedOrgTasks  TaskOrgReview[]      @relation("TaskOrgReviewer")
  plans             PersonalPlan[]
  scheduleEntries   ScheduleEntry[]
  profile           Profile?
  notifications     Notification[]
  awardRequests     AwardChangeRequest[] @relation("AwardRequestOwner")
  reviewedAwardRequests AwardChangeRequest[] @relation("AwardRequestReviewer")
  tagRequests       TagChangeRequest[]   @relation("TagRequestOwner")
  reviewedTagRequests TagChangeRequest[] @relation("TagRequestReviewer")
  gradeMajorRequests GradeMajorChangeRequest[] @relation("GradeMajorRequestOwner")
  reviewedGradeMajorRequests GradeMajorChangeRequest[] @relation("GradeMajorRequestReviewer")
  activityLogs      ActivityChangeLog[] @relation("ActivityLogActor")
}

model Organization {
  id            String   @id @default(uuid())
  nameZh        String
  nameEn        String
  nameRu        String
  descriptionZh String   @default("")
  descriptionEn String   @default("")
  descriptionRu String   @default("")
  typeZh        String
  typeEn        String
  typeRu        String
  leaderUserId  String?
  adminUserId   String?
  adminAccount  String?  @unique
  adminPassword String?  @default("")
  status        OrganizationStatus @default(ACTIVE)
  statusChangedAt DateTime?
  statusChangedById String?
  createdAt     DateTime @default(now())

  members      OrganizationMember[]
  tasks        Task[]               @relation("TaskPrimaryOrg")
  taskLinks    TaskOrganization[]
  orgReviews   TaskOrgReview[]
  activityLogs ActivityChangeLog[]
  adminUser    User?                @relation("OrganizationAdminUser", fields: [adminUserId], references: [id], onDelete: SetNull)
  leader       User?                @relation("OrganizationLeader", fields: [leaderUserId], references: [id], onDelete: SetNull)
}

model OrganizationMember {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  memberRole     OrganizationMemberRole @default(MEMBER)
  roleZh         String   @default("成员")
  roleEn         String   @default("Member")
  roleRu         String   @default("Участник")
  joinedAt       DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Task {
  startAt     DateTime?
  endAt       DateTime?
  id          String     @id @default(uuid())
  createdAt   DateTime   @default(now())
  titleZh     String
  titleEn     String
  titleRu     String
  descZh      String     @default("")
  descEn      String     @default("")
  descRu      String     @default("")
  status      TaskStatus @default(TODO)
  approvalStatus TaskApprovalStatus @default(APPROVED)
  source      TaskSource @default(LEAGUE_PUBLISHED)
  targetType  TaskTargetType @default(ORGS)
  targetGrade String?
  targetMajor String?
  targetClass String?
  reviewNote  String     @default("")
  approvedAt  DateTime?
  reviewedById String?
  dueAt       DateTime?
  creatorId   String
  assigneeId  String?
  primaryOrgId String?

  creator      User               @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee     User?              @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reviewedBy   User?              @relation("TaskReviewer", fields: [reviewedById], references: [id])
  primaryOrg   Organization?      @relation("TaskPrimaryOrg", fields: [primaryOrgId], references: [id])
  relatedOrgs   TaskOrganization[]
  orgReviews   TaskOrgReview[]
  notifications Notification[]
  activityLogs ActivityChangeLog[]
}

model TaskOrganization {
  taskId         String
  organizationId String

  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([taskId, organizationId])
}

model TaskOrgReview {
  taskId         String
  organizationId String
  status         OrgReviewStatus @default(PENDING)
  reviewerId     String?
  reviewedAt     DateTime?
  reason         String          @default("")

  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviewer     User?        @relation("TaskOrgReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@id([taskId, organizationId])
}

model PersonalPlan {
  startAt          DateTime?
  endAt            DateTime?
  id               String       @id @default(uuid())
  userId           String
  titleZh          String
  titleEn          String
  titleRu          String
  priority         PlanPriority @default(MEDIUM)
  source           PlanSource   @default(PERSONAL)
  dueAt            DateTime?
  syncedToTimeline Boolean      @default(true)
  createdAt        DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScheduleEntry {
  id         String @id @default(uuid())
  userId     String
  courseZh   String
  courseEn   String
  courseRu   String
  weekday    Int
  startTime  String
  endTime    String
  locationZh String @default("")
  locationEn String @default("")
  locationRu String @default("")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  userId        String                @id
  githubUrl     String?
  identityZh    String                @default("")
  identityEn    String                @default("")
  identityRu    String                @default("")
  reviewStatus  ProfileReviewStatus   @default(PENDING)
  rejectReason  String?
  submittedAt   DateTime?
  reviewedAt    DateTime?
  reviewedById  String?
  updatedAt     DateTime              @updatedAt

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("ProfileReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  awards     Award[]
  tags       SkillTag[]
}

model Award {
  id          String   @id @default(uuid())
  profileUserId String
  titleZh     String
  titleEn     String
  titleRu     String
  proofUrl    String?
  awardedAt   DateTime @default(now())

  profile Profile @relation(fields: [profileUserId], references: [userId], onDelete: Cascade)
  changeRequests AwardChangeRequest[]
}

model SkillTag {
  id            String @id @default(uuid())
  profileUserId String
  categoryZh    String
  categoryEn    String
  categoryRu    String
  nameZh        String
  nameEn        String
  nameRu        String

  profile Profile @relation(fields: [profileUserId], references: [userId], onDelete: Cascade)
  changeRequests TagChangeRequest[]
}

model AwardChangeRequest {
  id         String                   @id @default(uuid())
  userId     String
  action     ProfileItemAction
  awardId    String?
  titleZh    String                   @default("")
  titleEn    String                   @default("")
  titleRu    String                   @default("")
  proofUrl   String?                  @default("")
  status     ProfileItemRequestStatus @default(PENDING)
  reason     String?
  reviewerId String?
  reviewedAt DateTime?
  createdAt  DateTime                 @default(now())

  user     User   @relation("AwardRequestOwner", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User?  @relation("AwardRequestReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  award    Award? @relation(fields: [awardId], references: [id], onDelete: SetNull)
}

model TagChangeRequest {
  id         String                   @id @default(uuid())
  userId     String
  action     ProfileItemAction
  tagId      String?
  categoryZh String                   @default("")
  categoryEn String                   @default("")
  categoryRu String                   @default("")
  nameZh     String                   @default("")
  nameEn     String                   @default("")
  nameRu     String                   @default("")
  status     ProfileItemRequestStatus @default(PENDING)
  reason     String?
  reviewerId String?
  reviewedAt DateTime?
  createdAt  DateTime                 @default(now())

  user     User      @relation("TagRequestOwner", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User?     @relation("TagRequestReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  tag      SkillTag? @relation(fields: [tagId], references: [id], onDelete: SetNull)
}

model GradeMajorChangeRequest {
  id         String                   @id @default(uuid())
  userId     String
  fromGrade  String?
  fromMajor  String?
  toGrade    String?
  toMajor    String?
  status     ProfileItemRequestStatus @default(PENDING)
  reason     String?
  reviewerId String?
  reviewedAt DateTime?
  createdAt  DateTime                 @default(now())

  user     User  @relation("GradeMajorRequestOwner", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("GradeMajorRequestReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  titleZh   String
  titleEn   String
  titleRu   String
  bodyZh    String   @default("")
  bodyEn    String   @default("")
  bodyRu    String   @default("")
  read      Boolean  @default(false)
  taskId    String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

model ActivityChangeLog {
  id             String          @id @default(uuid())
  logType        ActivityLogType
  action         String
  entityId       String
  organizationId String?
  taskId         String?
  actorId        String?
  detailZh       String          @default("")
  detailEn       String          @default("")
  detailRu       String          @default("")
  createdAt      DateTime        @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  task         Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actor        User?         @relation("ActivityLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([logType, entityId, createdAt])
  @@index([organizationId, createdAt])
  @@index([taskId, createdAt])
}

model GradeOption {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

model MajorOption {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
}
