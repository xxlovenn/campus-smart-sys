# Copy to project root as .env for docker compose variable substitution
POSTGRES_USER=campus
POSTGRES_PASSWORD=mypassword123456
POSTGRES_DB=campus_smart

# 后端在 Docker 内的 DATABASE_URL 由 docker-compose 根据上面三项自动拼接。
# 本机 prisma migrate 请临时设置，端口与 compose 中 postgres 映射一致，例如映射 5433 时：
# DATABASE_URL=postgresql://campus:mypassword123456@localhost:5433/campus_smart?schema=public

JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

NEXT_PUBLIC_API_URL=http://localhost:3001/api
